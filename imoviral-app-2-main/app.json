      "favicon": "./public/favicon.png",
      "name": "INMOVIRAL",
      "shortName": "INMOVIRAL",
      "description": "Propiedades exclusivas de lujo en México.",
      "themeColor": "#141210",
      "backgroundColor": "#141210"
    },
    "extra": {
      "eas": {
        "projectId": "2d23cc55-b178-4e6c-8010-542dc80632e4"
      }
